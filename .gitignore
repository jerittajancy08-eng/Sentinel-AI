# ─────────────────────────────────────────────
# Sentinel AI — Root .gitignore
# ─────────────────────────────────────────────

# ── Python (backend / agents / core / api) ───────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# ── Environment & secrets ─────────────────────────────────
.env
.env.*
!.env.example
!frontend/.env.example
*.pem
*.key

# ── Frontend (Next.js) ────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/*.tsbuildinfo
frontend/next-env.d.ts
frontend/.env*.local

# ── Testing / coverage ─────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
coverage/

# ── Logs ────────────────────────────────────────────────────
*.log
logs/

# ── OS / Editor ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ── Docker ───────────────────────────────────────────────────
*.pid

# ── Azure deployment artifacts ────────────────────────────────
.azure/
*.zip
deploy/.deployment_temp/
node_modules/
