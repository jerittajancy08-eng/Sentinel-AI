# ─────────────────────────────────────────────
# Sentinel AI — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Microsoft Foundry Agent Service (HIGHEST PRIORITY) ──────
# Requires: pip install azure-ai-projects azure-ai-agents azure-identity
# Auth via DefaultAzureCredential — run `az login` locally, or set
# AZURE_CLIENT_ID / AZURE_TENANT_ID / AZURE_CLIENT_SECRET for a service principal.
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o

# Microsoft Foundry / Azure OpenAI (fallback #1)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Foundry Agent Service project info
FOUNDRY_PROJECT_NAME=sentinel-ai
FOUNDRY_SUBSCRIPTION_ID=
FOUNDRY_RESOURCE_GROUP=

# Fallback #2: direct OpenAI key (free-tier / student account)
OPENAI_API_KEY=

# Mock mode (fallback #3) — set to "true" to run fully offline with
# deterministic heuristic scoring (no API key required). Great for demos.
SENTINEL_MOCK_MODE=true
